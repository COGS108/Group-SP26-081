   "cell_type": "code",
   "execution_count": 38,
   "metadata": {},
   "outputs": [],
   "source": [
    "#a function used to change object data to numbers\n",
    "def clean_memory(x):\n",
    "    if pd.isna(x):\n",
    "        return np.nan\n",
    "    x = str(x).lower().replace(\" \", \"\")\n",
    "    if \"gb\" in x:\n",
    "        return float(x.replace(\"gb\", \"\")) * 1024\n",
    "    if \"mb\" in x:\n",
    "        return float(x.replace(\"mb\", \"\"))\n",
    "    return np.nan\n",
    "\n",
    "def numeric_clean(x):\n",
    "    if pd.isna(x):\n",
    "        return np.nan\n",
    "    x = str(x)\n",
    "    for unit in [\"ghz\", \"mhz\", \"hz\", \",\"]:\n",
    "        x = x.replace(unit, \"\")\n",
    "    return pd.to_numeric(x, errors = \"coerce\")"
   ]
