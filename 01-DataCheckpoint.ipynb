    "## YOUR CODE TO LOAD/CLEAN/TIDY/WRANGLE THE DATA GOES HERE\n",
    "#Step 1: Loading in the dataset\n",
    "df1 = pd.read_csv('data/00-raw/videogame_requirements.csv')\n",
    "\n",
    "#Step 2: Check the structure of the dataset\n",
    "df1.info()\n",
    "\n",
    "#Step 3: Get the size of the dataset\n",
    "print(\"Original dataset shape:\\n\", df1.shape)\n",
    "\n",
    "#Step 4: finding how many missing values\n",
    "total=df1.isna().sum()\n",
    "\n",
    "#figuring out the percentage\n",
    "precentage=(df1.isna().mean()*100).round(2)\n",
    "\n",
    "#how many rows are missing values\n",
    "missing_rows = df1[df1.isna().any(axis=1)]\n",
    "\n",
    "print(\"Total values missing:\\n\", total)\n",
    "print(\"Shape of all the missing values:\\n\", missing_rows.shape)\n",
    "\n",
    "#finding if the missing value is random or not\n",
    "missing_indicators = df1.isna().astype(int)\n",
    "missing_indicators.corr()\n",
    "sns.heatmap(missing_indicators.corr(), annot = False, cmap = 'viridis')\n",
    "plt.show()\n",
    "\n",
    "#converting object data to numbers\n",
    "df1['Release_Date'] = pd.to_datetime(df1['Release_Date'], errors = 'coerce')\n",
    "df1['Release_Year'] = df1['Release_Date'].dt.year\n",
    "\n",
    "df1['Min_RAM_MB'] = df1['Min_RAM'].apply(clean_memory)\n",
    "df1['Min_VRAM_MB'] = df1['Min_VRAM'].apply(clean_memory)\n",
    "\n",
    "df1['Min_GPU_Memory'] = df1['Min_GPU_Memory'].apply(numeric_clean)\n",
    "df1['Min_GPU_Boost_Clock'] = df1['Min_GPU_Boost_Clock'].apply(numeric_clean)\n",
    "df1['Min_GPU_Memory_Bandwidth'] = df1['Min_GPU_Memory_Bandwidth'].apply(numeric_clean)\n",
    "\n",
    "#Step 5: finding any outliers\n",
    "numeric_cols = df1.select_dtypes(include=[float, int]).columns\n",
    "\n",
    "# finding the z-score\n",
    "z = np.abs((df1[numeric_cols] - df1[numeric_cols].mean()) / df1[numeric_cols].std())\n",
    "outlier = df1[(z>3).any(axis=1)]\n",
    "print(\"Shape of all the outliers:\\n\", outlier.shape)\n",
    "\n",
    "#flagging the oulier by adding a column\n",
    "df1['outlier_flag'] = (z>3).any(axis=1)\n",
    "\n",
    "#keeping columns that are relevant\n",
    "kept_cols = [\"Name\", \"Release_Date\", \"Release_Year\", \"Min_CPU_CPU_Speed\",\n",
    "             \"Min_CPU_Turbo_Speed\", \"Min_CPU_Physical_Cores\", \"Min_CPU_Threads\",\n",
    "             \"Min_CPU_GD_Rating\", \"Min_GPU_Shader\", \"Min_GPU_Direct_X\", \"Min_GPU_Memory\",\n",
    "             \"Min_GPU_GD_RATING\", \"Min_GPU_Boost_Clock\", \"Min_GPU_Memory_Bandwidth\", \"Min_GPU_Process\",\n",
    "             \"Min_RAM_MB\", \"Min_VRAM_MB\"]\n",
    "df1_reduced = df1[kept_cols].copy()\n",
    "\n",
    "#Step 6: cleaning up the data\n",
    "clean_df1 = df1_reduced.dropna(how='any').copy()\n",
    "clean_df1.to_csv('data/01-interim/videogame_requirements_cleaned.csv', index=False)\n",
    "\n",
    "#processing the final dataset after cleaning it\n",
    "processed_df1= clean_df1.copy()\n",
    "processed_df1.to_csv('data/02-processed/videogame_requirements_processed.csv', index=False)\n",
    "\n",
    "print(processed_df1.head())"
